NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # 서버 전용. 절대 클라이언트에 노출 금지

# --- Anthropic Claude (단계 4: 공부 LLM 추출) ---
